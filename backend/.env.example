PORT=3000

# 32-byte AES-256 key for encrypting Razorpay secrets at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: If you change this, existing PaymentSources must be re-added.
ENCRYPTION_KEY=<64-char hex string>

NODE_ENV=development

# PostgreSQL connection string.
# Local:    DATABASE_URL="postgresql://user:pass@localhost:5432/payrecover"
# Neon:     DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/payrecover?sslmode=require"
# Supabase: DATABASE_URL="postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres"
DATABASE_URL="postgresql://user:pass@localhost:5432/payrecover"

# Redis connection string (used by BullMQ for the recovery job queue).
# Local:   REDIS_URL="redis://localhost:6379"
# Upstash: REDIS_URL="rediss://default:token@xxx.upstash.io:6380"
REDIS_URL="redis://localhost:6379"

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<64-char hex string>

ALLOWED_ORIGINS=http://localhost:5173

# Optional: used as the callback_url in generated payment links
# FRONTEND_URL=http://localhost:5173

# Razorpay credentials — get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
# Get webhook secret from Dashboard > Webhooks after creating a webhook
RAZORPAY_WEBHOOK_SECRET=xxxx

# Email (SMTP) — without these, emails are printed to console (dev mode)
# Gmail:     SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  (use an App Password)
# SendGrid:  SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=PayRecover <noreply@yourdomain.com>

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URIs to: http://localhost:3000/api/auth/google/callback (dev)
#                               or https://your-domain.com/api/auth/google/callback (prod)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
